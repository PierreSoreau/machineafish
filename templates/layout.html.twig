		<!--Ce script permet que google accepte la vidéo sur son site pour 
		qu'elle soit indexée et visible sur leur plateforme(notamment dans l'onglet vidéo). 
		Là c'est la vidéo vu drone de la page d'accueil-->
		<script type="application/ld+json">
			{
  				"@context": "https://schema.org",
  				"@type": "VideoObject",
  				"name": "Vidéo d'accueil Machine à Fish",
  				"description": "Vidéo d'arrière-plan de la page d'accueil de Machine à Fish, dévoilant un paysage de campagne, une rivière et une immersion dans les fonds aquatiques",
  				"thumbnailUrl": "https://machineafish.fr/assets/images/vignette_accueil.webp",
  				"uploadDate": "2023-10-01T08:00:00+02:00",
  				"contentUrl": "https://machineafish.fr/assets/videos/video_accueil.webm"
			}
		</script>
		<title>
			{% block title %}
				MachineAFish | La pêche aux leurres accessible à tous
			{% endblock %}
		</title>
		<meta
		name="description" content="{% block description %}Découvrez MachineAFish, le guide ultime pour débuter la pêche aux leurres en eau douce. 
		Découverte des carnassiers, tutoriels techniques et matériel conseillés pour vos premières sorties.{% endblock %}">
		<!-- ce link permet de charger les vidéos youtube rapidement sur la page sans qu'elle prenne du temps à s'afficher sur l'écran-->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lite-youtube-embed/src/lite-yt-embed.css">
		<script src="https://cdn.jsdelivr.net/npm/lite-youtube-embed/src/lite-yt-embed.js"></script>

		<!--Cette balise permet d'avoir le logo du site sur l'onglet de l'utilisateur et dans les résultats de recherche google-->
		<link rel="icon" href="https://machineafish.fr/assets/images/favicon.png" type="image/png" sizes="96x96">

		<!--Ces balises meta permettent aux réseaux sociaux de savoir quoi 
		mettre sur la petite feuille du lien qui s'affiche quand on partage un lien dans une conversation (image et texte sous l'image)-->
		<meta property="og:title" content="MachineAFish | La pêche aux leurres accessible à tous" />

		<meta property="og:description" content="Découvrez MachineAFish, le guide ultime pour débuter la pêche aux leurres en eau douce. 
		Découverte des carnassiers, tutoriels techniques et matériel conseillés pour vos premières sorties." />

		<meta property="og:image" content="https://machineafish.fr/assets/images/vignette_accueil.webp" />

		<meta property="og:type" content="website" />
	</head>

	<body>
		{% include "partials/_header.html.twig" %}

		{% block main %}{% endblock %}

		<div class="blur-overlay"></div>

		{% include "partials/_footer.html.twig" %}

		{% block javascripts %}
			<script src="script_header.js"></script>
		{% endblock %}


	</body>
</html>
