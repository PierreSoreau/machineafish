{% extends 'layout.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="assets/css/materiel.css">
{% endblock %}

{% block title %}
	Listes Materiel
{% endblock %}

{% block description %}
	Materiels personnalisés en fonction des besoins de l'utilisateur (canne,moulinet,fil,leurres)
{% endblock %}

{% block main %}
	<main>
		<h2>Voici la sélection idéale pour pêcher</h2>
		<h1>le
			{{name_fish}}</h1>
		<a class="precedent" href="index.php?route=questions">
			<i class="fa-solid fa-circle-chevron-left fa-3x"></i>
			<p>Revenir aux questions</p>
		</a>
		<section id="matos">
			<div class="matos_detail">
				<div class="nom_materiel_container">
					<div class="nom_materiel">
						<h3 class="nom_matos canne">CANNE</h3>
					</div>
				</div>
				<img src="{{repeat.contenuurl}}{{ urlimages[0]['url'] }}{{repeat.extensionurl}}" alt="logo_canne" class="logo_matos"/>
				<div class="matos_container">
					<div class="matos_box">
						<div class="box-infos">
							<div class="matos_titre">
								<img src="{{repeat.contenuurl}}{{ urlimages[6]['url'] }}{{repeat.extensionurl}}" alt="logo_longueur"/>
								<h3>Longueur</h3>
							</div>
							<p>{{ canne.longueur}}</p>
						</div>
						<div class="button-infos">
							<img src="{{repeat.contenuurl}}v1770053329/info_iaivj2{{repeat.extensionurl}}" class="infos" data-target="info_number1" alt="logo infos">
						</div>
					</div>
					<div class="matos_box">
						<div class="box-infos">
							<div class="matos_titre">
								<img src="{{repeat.contenuurl}}{{ urlimages[5]['url'] }}{{repeat.extensionurl}}" alt="logo_puissance"/>
								<h3>Puissance</h3>
							</div>
							<p>{{ canne.poids_mini ~ "g - " ~ canne.poids_maxi ~ "g"}}</p>
						</div>
						<div class="button-infos">
							<img src="{{repeat.contenuurl}}v1770053329/info_iaivj2{{repeat.extensionurl}}" class="infos" data-target="info_number2" alt="logo infos">
						</div>
					</div>
					<div class="matos_box action">
						<div class="box-infos">
							<div class="matos_titre">
								<img src="{{repeat.contenuurl}}{{ urlimages[4]['url'] }}{{repeat.extensionurl}}" alt="logo_action"/>
								<h3>Action</h3>
							</div>
							<p>{{ canne.action}}</p>
						</div>
						<div class="button-infos">
							<img src="{{repeat.contenuurl}}v1770053329/info_iaivj2{{repeat.extensionurl}}" class="infos" data-target="info_number3" alt="logo infos">
						</div>
					</div>
				</div>
			</div>
			<div class="matos_detail">
				<div class="nom_materiel_container">
					<div class="nom_materiel">
						<h3 class="nom_matos moulinet">MOULINET</h3>
					</div>
				</div>
				<img src="{{repeat.contenuurl}}{{ urlimages[1]['url'] }}{{repeat.extensionurl}}" alt="logo_moulinet" class="logo_matos"/>
				<div class="matos_container">
					<div class="matos_box">
						<div class="box-infos">
							<div class="matos_titre">
								<img src="{{repeat.contenuurl}}{{ urlimages[6]['url'] }}{{repeat.extensionurl}}" alt="logo_longueur"/>
								<h3>Taille bobine</h3>
							</div>
							<p>{{ moulinet.taille_bobine}}</p>
						</div>
						<div class="button-infos">
							<img src="{{repeat.contenuurl}}v1770053329/info_iaivj2{{repeat.extensionurl}}" class="infos" data-target="info_number4" alt="logo infos">
						</div>
					</div>
					<div class="matos_box">
						<div class="box-infos">
							<div class="matos_titre">
								<img class="logo_fil" src="{{repeat.contenuurl}}{{ urlimages[8]['url'] }}{{repeat.extensionurl}}" alt="logo_ratio_moulinet"/>
								<h3>Ratio</h3>
							</div>
							<p>{{ moulinet.ratio}}</p>
						</div>
						<div class="button-infos">
							<img src="{{repeat.contenuurl}}v1770053329/info_iaivj2{{repeat.extensionurl}}" class="infos" data-target="info_number5" alt="logo infos">
						</div>
					</div>
				</div>
			</div>
			<div class="matos_detail">
				<img src="{{repeat.contenuurl}}v1770053329/info_iaivj2{{repeat.extensionurl}}" class="infos info-mater" data-target="info_number8" alt="logo infos">
				<div class="nom_materiel_container">
					<div class="nom_materiel">
						<h3 class="nom_matos fil">FIL</h3>
					</div>
				</div>
				<img src="{{repeat.contenuurl}}{{ urlimages[3]['url'] }}{{repeat.extensionurl}}" alt="logo_fil" class="logo_matos fil"/>
				<div class="matos_container">
					<div class="matos_box">
						<div class="box-infos">
							<div class="matos_titre fil">
								<img class="logo_fil" src="{{repeat.contenuurl}}{{ urlimages[7]['url'] }}{{repeat.extensionurl}}" alt="logo_type_fil"/>
								<h3 class="titre_fil">Diamètre Tresse</h3>
							</div>
							<p>{{ fil.epaisseur_de_tresse}}</p>
						</div>
						<div class="button-infos">
							<img src="{{repeat.contenuurl}}v1770053329/info_iaivj2{{repeat.extensionurl}}" class="infos" data-target="info_number6" alt="logo infos">
						</div>
					</div>
					<div class="matos_box">
						<div class="box-infos">
							<div class="matos_titre fil">
								<img class="logo_fil" src="{{repeat.contenuurl}}{{ urlimages[7]['url'] }}{{repeat.extensionurl}}" alt="logo_type_fil"/>
								<h3 class="titre_fil">Diamètre Fluorocarbone</h3>
							</div>
							<p>{{ fil.epaisseur_de_fluorocarbone}}</p>
						</div>
						<div class="button-infos">
							<img src="{{repeat.contenuurl}}v1770053329/info_iaivj2{{repeat.extensionurl}}" class="infos" data-target="info_number7" alt="logo infos">
						</div>
					</div>
				</div>
			</div>
			<div class="matos_detail">
				<div class="nom_materiel_container">
					<div class="nom_materiel">
						<h3 class="nom_matos leurres">LEURRES</h3>
					</div>
				</div>
				<img class="leurre" src="{{repeat.contenuurl}}{{ urlimages[2]['url'] }}{{repeat.extensionurl}}" alt="logo_leurre" class="logo_matos"/>
				<div class="leurre_container">
					{% for leurre in leurres %}
						<div class="leurre-box">
							<img class="photo_leurre" src="{{repeat.contenuurl}}{{leurre.photo}}{{repeat.extensionurl}}" alt="visuel_leurre"/>
							<div class="matos_titre leurre">
								<h3 class="nom_leurre">{{leurre.nom}}</h3>
							</div>
						</div>
					{% endfor %}
				</div>
			</div>
		</section>

		{% for info in infos %}
			<div id="info_number{{info.id}}" class="infos-box">
				<i class="fa-solid fa-2xl fa-xmark closeinfos"></i>
				<h2>{{info.caracteristiques}}</h2>
				<div class="schema-scroll-zone number{{info.id}}">
					<div class="visuel_explication">
						<img src="{{repeat.contenuurl}}{{info.image}}{{repeat.extensionurl}}" alt="{{info.caracteristiques}}" class="infos-image number{{info.id}}">
					</div>
					<p class="infos-p number{{info.id}}">{{info.description | raw}}</p>
				</div>
			</div>
		{% endfor %}

	</main>
{% endblock %}

{% block javascripts %}
	<script src="materiel.js"></script>
	{{ parent() }}
{% endblock %}
